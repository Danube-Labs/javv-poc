# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# Node / frontend
node_modules/
.vite/
frontend/dist/

# Env / secrets
.env
.env.*
!.env.example
*.pem

# Scanner artifacts
*.dead-letter.jsonl
trivy-cache/
grype-cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Serena MCP — project.yml is committed (shared config); .serena/.gitignore handles
# the local cache + project.local.yml, so no blanket ignore here.

# Claude Code — personal local settings (team config lives in .claude/settings.json)
.claude/settings.local.json

# Local-only audit/working tracker (temporary; never committed)
development/AUDIT.md

# Session handoffs — local snapshots by default (commit the infra, not the snapshots).
# git add -f a specific one to share it.
.claude/sessions/*.md
!.claude/sessions/README.md
!.claude/sessions/TEMPLATE.md

# Codex (second independent auditor) — local setup, not part of the repo.
.codex/
AGENTS.md

# e2e run artifacts — commit the harness + results.md, never the run logs.
development/e2e/logs/
backend/cookies.txt
